{
  "name": "dnd-game",
  "version": "0.0.1",
  "private": true,
  "description": "D&D 5e 单人游戏 - AI 地下城主",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:server": "turbo run dev --filter=server",
    "dev:all": "pnpm --filter web dev & pnpm --filter server dev",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "build:server": "turbo run build --filter=server",
    "lint": "turbo run lint",
    "lint:web": "turbo run lint --filter=web",
    "lint:server": "turbo run lint --filter=server",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "clean:all": "rm -rf apps/web/dist apps/server/node_modules apps/web/node_modules node_modules"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "npm-run-all": "^4.1.5",
    "turbo": "^2.0.0",
    "ws": "^8.19.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
