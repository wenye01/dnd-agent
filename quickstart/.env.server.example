# ============================================================
# D&D Game Server - 环境变量配置
# ============================================================
# 复制此文件到 apps/server/.env 并填入你的配置
#   cp quickstart/.env.server.example apps/server/.env
#
# 注意: 服务端配置主要通过 config.yaml 管理，此文件中的
# 环境变量用于 config.yaml 中的 ${VAR:-default} 展开以及
# Viper 的 DND_ 前缀环境变量覆盖。
# ============================================================

# ---- LLM 配置 (config.yaml 通过 ${VAR:-default} 引用) ----

# LLM API Key (必填)
MINIMAX_API_KEY=your-api-key-here

# MiniMax API Base URL (可选，已有默认值)
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# MiniMax 模型 (可选，已有默认值)
# MINIMAX_MODEL=MiniMax-M2.7

# ---- 切换 LLM 提供商 ----
# 如需使用 OpenAI，取消下方注释并填入 Key:
# DND_LLM_PROVIDER=openai
# DND_LLM_OPENAI_API_KEY=your-openai-key
# DND_LLM_OPENAI_BASE_URL=https://api.openai.com/v1
# DND_LLM_OPENAI_MODEL=gpt-4o

# 如需使用 GLM，取消下方注释并填入 Key:
# DND_LLM_PROVIDER=glm
# DND_LLM_OPENAI_API_KEY=your-glm-key
# DND_LLM_OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# DND_LLM_OPENAI_MODEL=glm-4

# ---- 高级配置 (可选，通过 DND_ 前缀覆盖 config.yaml) ----
# DND_SERVER_PORT=8080
# DND_LOG_LEVEL=debug
# DND_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
