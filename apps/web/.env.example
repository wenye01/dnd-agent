# WebSocket Configuration
# WebSocket server URL
VITE_WS_URL=ws://localhost:8080/ws

# WebSocket reconnection interval in milliseconds
VITE_WS_RECONNECT_INTERVAL=3000

# Maximum number of reconnection attempts
VITE_WS_MAX_RECONNECT_ATTEMPTS=10

# Heartbeat/ping interval in milliseconds
VITE_WS_HEARTBEAT_INTERVAL=30000

# API Configuration
# Backend API base URL (if separate from WebSocket)
VITE_API_URL=http://localhost:8080/api

# LLM Configuration (for AI Dungeon Master features)
# Note: These are typically handled by the backend, but may be needed for direct API calls
VITE_LLM_API_URL=
VITE_LLM_API_KEY=
VITE_LLM_MODEL=

# Application Configuration
# Application name
VITE_APP_NAME=DND Game Client

# Enable debug mode (shows additional console logs)
VITE_DEBUG=true
