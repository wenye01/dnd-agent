# 应用配置
APP_NAME=dnd-game
APP_ENV=development
APP_DEBUG=true

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=dnd_game
DB_SSLMODE=disable

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 配置
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRATION=24h

# CORS 配置
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# WebSocket 配置
WS_READ_BUFFER_SIZE=1024
WS_WRITE_BUFFER_SIZE=1024
WS_PING_PERIOD=54s
WS_PONG_WAIT=60s

# 日志配置
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_OUTPUT=stdout

# 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# 文件上传
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/png,image/jpeg,image/gif

# 游戏配置
GAME_MAX_PLAYERS_PER_ROOM=6
GAME_TURN_TIMEOUT=30000
GAME_AUTO_SAVE_INTERVAL=60000

# 功能开关
FEATURE_WEBSOCKET=true
FEATURE_CHAT=true
FEATURE_VOICE_CHAT=false
FEATURE_FILE_UPLOAD=true
